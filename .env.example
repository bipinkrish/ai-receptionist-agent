# LLM provider — set ONE of these:
OPENROUTER_API_KEY=your_openrouter_api_key_here
# GROQ_API_KEY=your_groq_api_key_here   # fallback if OPENROUTER_API_KEY is not set

# Auth option A: path to service account JSON file
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=./service-account.json

# Auth option B: inline credentials (no JSON file on disk)
# GOOGLE_SERVICE_ACCOUNT_EMAIL=your-sa@project.iam.gserviceaccount.com
# GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Auth option C: paste the whole JSON as one env var (good for cloud hosts)
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# Auth option D: omit file/inline vars and use Application Default Credentials
# (run `gcloud auth application-default login` for local dev)

STUDIO_TIMEZONE=America/Los_Angeles
CALENDAR_ID=your_calendar_id@group.calendar.google.com
SHEET_ID=your_google_sheet_id

# Backend (Koyeb): npm run tools — API only (text chat + Vapi webhook)
# Local dev: npm run ui — API + serves public/index.html
# CORS_ORIGIN=https://YOUR_USER.github.io

# Public backend URL (Koyeb). Used by GH Pages frontend + Vapi assistant setup.
API_BASE_URL=https://your-app.koyeb.app

# Vapi voice (private key also used on backend to auto-hangup after logContact)
VAPI_PRIVATE_KEY=your_vapi_private_key
VAPI_PUBLIC_KEY=your_vapi_public_key
VAPI_ASSISTANT_ID=assistant_id_from_vapi_create_script
# TOOL_SERVER_URL defaults to ${API_BASE_URL}/vapi/tools
